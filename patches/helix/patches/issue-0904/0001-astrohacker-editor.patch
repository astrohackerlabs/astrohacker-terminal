@@ -0,0 +1,23 @@
+#!/usr/bin/env fish
+# Fish completion script for Helix editor
+
+complete -c ahe -s h -l help -d "Prints help information"
+complete -c ahe -l strict -d "Bail on error for commands that can fail"
+complete -c ahe -l tutor -d "Loads the tutorial"
+complete -c ahe -l health -xa "(__ahe_langs_ops)" -d "Checks for errors"
+complete -c ahe -l health -xka all -d "Prints all diagnostic informations"
+complete -c ahe -l health -xka all-languages -d "Lists all languages"
+complete -c ahe -l health -xka languages -d "Lists user configured languages"
+complete -c ahe -l health -xka clipboard -d "Prints system clipboard provider"
+complete -c ahe -s g -l grammar -x -a "fetch build" -d "Fetch or build tree-sitter grammars"
+complete -c ahe -s v -o vv -o vvv -d "Increases logging verbosity"
+complete -c ahe -s V -l version -d "Prints version information"
+complete -c ahe -l vsplit -d "Splits all given files vertically"
+complete -c ahe -l hsplit -d "Splits all given files horizontally"
+complete -c ahe -s c -l config -r -d "Specifies a file to use for config"
+complete -c ahe -l log -r -d "Specifies a file to use for logging"
+complete -c ahe -s w -l working-dir -d "Specify initial working directory" -xa "(__fish_complete_directories)"
+
+function __ahe_langs_ops
+    ahe --health all-languages | tail -n '+2' | string replace -fr '^(\S+) .*' '$1'
+end
